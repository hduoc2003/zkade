SERVER_HOST=localhost
SERVER_PORT=8000

# Soroban sudoku contract id (C...)
GAME_CONTRACT=C...
# Stellar CLI identity alias (or S... secret) the server signs owner txs with
GAME_OWNER=zkade
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Service fee per room, in token base units (stroops for XLM; 1 XLM = 10_000_000)
SERVICE_FEE=1000000

# RISC Zero proving. Leave Bonsai vars unset to prove locally (free, needs
# Docker for the Groth16 wrap). Set both to use the Bonsai network.
# BONSAI_API_KEY=...
# BONSAI_API_URL=https://api.bonsai.xyz/
# RISC0_DEV_MODE=1   # mock receipts for fast iteration (NOT verifiable on-chain)
