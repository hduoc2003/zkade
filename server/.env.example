SERVER_HOST=localhost
SERVER_PORT=8000

# Soroban sudoku contract id (C...)
GAME_CONTRACT=C...
# Stellar CLI identity alias (or S... secret) the server signs owner txs with
GAME_OWNER=zkade
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Service fee per room, in token base units (stroops for XLM; 1 XLM = 10_000_000)
SERVICE_FEE=1000000

# RISC Zero proving.
# Preferred: a remote stateless prover (full /generate-proof URL). When set, all
# proving is offloaded here and no local r0vm/Docker is needed.
# PROVER_URL=http://<prover-host>:<port>/api/v1/generate-proof
# If PROVER_URL is unset, proofs are generated locally (free, needs Docker for the
# Groth16 wrap), or on Bonsai when both vars below are set.
# BONSAI_API_KEY=...
# BONSAI_API_URL=https://api.bonsai.xyz/
# RISC0_DEV_MODE=1   # mock receipts for fast iteration (NOT verifiable on-chain)
